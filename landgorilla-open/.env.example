# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────────────────────────
# Option A: Local PostgreSQL (individual vars)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=loanscope
DB_USER=loanscope
DB_PASSWORD=loanscope_dev
DB_POOL_MAX=20

# Option B: Supabase — use ONE of these connection strings.
# If DATABASE_URL is set it takes priority over the individual vars above.
#
# Direct connection (best for local dev / long-running processes):
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
#
# Transaction pooler (recommended for Vercel serverless, port 6543):
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=24h

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*

# ── Rate limiting (requests per 15 minutes) ───────────────────────────────────
RATE_LIMIT_MAX=100
