# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=loanscope
DB_USER=loanscope
DB_PASSWORD=loanscope_dev
DB_POOL_MAX=20

# JWT — change this to a long random string in production!
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=*

# Rate limiting (requests per 15 minutes)
RATE_LIMIT_MAX=100
